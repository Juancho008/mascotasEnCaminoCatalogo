{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    { "src": "api/catalog.cjs", "use": "@vercel/node" },
    { "src": "api/pdfs.cjs", "use": "@vercel/node" },
    { "src": "api/admin-catalog.cjs", "use": "@vercel/node" },
    { "src": "api/admin-upload.cjs", "use": "@vercel/node" },
    { "src": "api/admin-import-pdf.cjs", "use": "@vercel/node" },
    { "src": "api/admin-upload-image.cjs", "use": "@vercel/node" },
    { "src": "api/product-image.cjs", "use": "@vercel/node" },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "client/dist" }
    }
  ],
  "routes": [
    { "src": "/api/admin/import-pdf", "dest": "/api/admin-import-pdf.cjs" },
    { "src": "/api/admin/upload-image", "dest": "/api/admin-upload-image.cjs" },
    { "src": "/api/product-image", "dest": "/api/product-image.cjs" },
    { "src": "/api/admin/upload-pdf", "dest": "/api/admin-upload.cjs" },
    { "src": "/api/admin/catalog", "dest": "/api/admin-catalog.cjs" },
    { "src": "/api/catalog", "dest": "/api/catalog.cjs" },
    { "src": "/api/pdfs", "dest": "/api/pdfs.cjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
