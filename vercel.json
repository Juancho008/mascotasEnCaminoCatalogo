{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/catalog.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "api/documents.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "api/admin/catalog.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "api/admin/documents.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "client/dist" }
    }
  ],
  "routes": [
    { "src": "/api/catalog", "dest": "/api/catalog.cjs" },
    { "src": "/api/documents", "dest": "/api/documents.cjs" },
    { "src": "/api/admin/catalog", "dest": "/api/admin/catalog.cjs" },
    { "src": "/api/admin/documents", "dest": "/api/admin/documents.cjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
