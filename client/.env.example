# El frontend llama a /api/catalog (proxy en Vercel con HMAC).
# No hace falta VITE_CATALOG_API en producción si usás el proxy.

# Solo para desarrollo si querés forzar otra URL:
# VITE_CATALOG_API=/api/catalog

# URL pública del sitio (canonical, Open Graph, sitemap). Sin barra final.
# VITE_SITE_URL=https://mascotas-en-camino-catalogo-eight.vercel.app
