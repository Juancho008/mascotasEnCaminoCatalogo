{
  "name": "mascotas-en-camino-catalogo",
  "version": "1.0.0",
  "description": "Catálogo de productos para mascotas configurable, sin base de datos, con carrito temporal y checkout por WhatsApp.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c magenta,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "build:static": "node scripts/build-static.mjs",
    "vercel-build": "node scripts/build-static.mjs && npm --prefix client install && npm --prefix client run build",
    "kv:sync": "node scripts/build-static.mjs && node scripts/sync-kv.mjs",
    "kv:sanitize": "node scripts/sanitize-kv-catalog.mjs",
    "hmac:test": "node scripts/test-hmac.mjs",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "start": "node server/index.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "compression": "^1.7.5",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "wrangler": "^4.14.0"
  }
}
