# Secretos del servidor (NO usar prefijo VITE_ — no van al navegador)
# Copiá a .env en la raíz para desarrollo local con proxy HMAC.

# URL del Worker (solo dominio, SIN /catalog.json)
CATALOG_WORKER_URL=https://mascotas-catalogo-api.juanignacioespindola08.workers.dev

# Mismo secreto que configurás en Cloudflare:
# npx wrangler secret put CATALOG_HMAC_SECRET
CATALOG_HMAC_SECRET=genera-un-secreto-largo-y-aleatorio-aqui
